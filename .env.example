# Base Sepolia RPC (Alchemy)
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Public Base Sepolia RPC for eth_getLogs (no Alchemy rate limits)
BASE_SEPOLIA_LOGS_RPC=https://sepolia.base.org

# Deployer wallet private key (NO 0x prefix)
