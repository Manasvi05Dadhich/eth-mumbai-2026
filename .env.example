# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key_here

# BitGo (Phase 4)
BITGO_ACCESS_TOKEN=your_bitgo_testnet_token_here
BITGO_ENTERPRISE_ID=your_enterprise_id_here
BITGO_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Agent config (optional overrides)
BLOCK_LOOKBACK=5000
