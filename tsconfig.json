{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "../config": [
                "./config.ts"
            ]
        }
    },
    "include": [
        "config.ts",
        "agent/src/**/*",
        "bitgo/src/**/*"
    ],
    "exclude": [
        "node_modules",
        "frontend",
        "circuits",
        "contracts"
    ]
}